{
    "name": "plasmargon/industrial-welding",
    "type": "wordpress-theme",
    "description": "Industrial Welding is a WooCommerce theme for overseas welding machine catalogs, shortlist comparison, and quote-first conversion flows.",
    "keywords": [
        "WordPress",
        "Themes",
        "WooCommerce",
        "Industrial"
    ],
    "homepage": "https://plasmargon.com/",
    "version": "2.2.1",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Plasmargon Development Team",
            "homepage": "https://plasmargon.com/"
        }
    ],
    "require": {
        "php": ">=8.0"
    },
    "require-dev": {
        "dealerdirect/phpcodesniffer-composer-installer": "^0.7.0",
        "wptrt/wpthemereview": "^0.2.1",
        "php-parallel-lint/php-parallel-lint": "^1.2.0",
        "wp-cli/i18n-command": "^2.2.5"
    },
    "scripts": {
        "lint:wpcs": "@php ./vendor/squizlabs/php_codesniffer/bin/phpcs",
        "lint:php": "@php ./vendor/bin/parallel-lint --exclude .git --exclude vendor .",
        "make-pot": "wp i18n make-pot . languages/industrial-welding.pot --slug=industrial-welding --domain=industrial-welding --exclude=node_modules,vendor,0_"
    }
}
